# =============================================================================
# Copy to `.env` and fill in values. Load order matches `rag_lab.config.Settings`.
# =============================================================================

# --- LangSmith (tracing + LangSmith eval datasets / experiments) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=rag-agent-tutorial

# --- Google Gemini API ---
# Required when CHAT_PROVIDER=google, JUDGE_PROVIDER=google, or EMBEDDING_PROVIDER=google.
# Omit only if all three use ollama (then no Gemini calls).
GOOGLE_API_KEY=your_google_api_key_here

# --- Chat LLM ---
# CHAT_PROVIDER: google | ollama
# - google: CHAT_MODEL is a Gemini short name (e.g. gemini-2.5-flash-lite); prefixed internally.
# - ollama: CHAT_MODEL is the Ollama tag (e.g. qwen2.5:7b); pull first: ollama pull qwen2.5:7b
CHAT_PROVIDER=google
CHAT_MODEL=gemini-2.5-flash-lite

# --- Bench: LLM-as-judge (LangSmith evaluate) ---
# JUDGE_PROVIDER: google | ollama
JUDGE_PROVIDER=google
JUDGE_MODEL=gemini-2.5-flash

# --- Embeddings (index + retrieval) ---
# EMBEDDING_PROVIDER: ollama | google
EMBEDDING_PROVIDER=ollama
# When EMBEDDING_PROVIDER=ollama (alias OLLAMA_EMBED_MODEL):
EMBEDDING_MODEL=nomic-embed-text
# When EMBEDDING_PROVIDER=google, set instead:
# GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

OLLAMA_BASE_URL=http://localhost:11434

# --- DEV.to corpus ---
DEVTO_USERNAME=fortune-ndlovu
# Optional: raise if you publish more than this many posts (single-page listing cap).
# DEVTO_LISTING_PER_PAGE=1000

# --- Persistence ---
CHROMA_DIR=./.chroma
CHROMA_COLLECTION=fortune_devto
SQLITE_THREADS_PATH=./.threads.sqlite

# --- LangSmith dataset name for bench (must match or recreate dataset in UI) ---
EVAL_DATASET_NAME=fortune-devto-qa-v1

# --- Optional notes (ignored by app; safe for bookmarks) ---
# BLOG_POST_URL=https://dev.to/fortune-ndlovu/your-post-slug
